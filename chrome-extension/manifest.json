{
  "manifest_version": 3,
  "name": "Workday Auto Login",
  "version": "1.0.0",
  "description": "Automatically fills Workday login forms with saved credentials",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.workday.com/*",
    "*://*.myworkday.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.workday.com/*",
        "*://*.myworkday.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Workday Auto Login"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
